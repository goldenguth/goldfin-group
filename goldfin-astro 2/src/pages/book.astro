---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Book a 15-Minute Call — Goldfin Group"
  description="Schedule a free 15-minute call with Ryan Guth, CFP®. No pitch, no pressure. Just the questions you should be asking before, during, or after the sale of your business."
  path="/book"
>
<div class="pagehead">
  <div class="wrap" style="max-width:760px">
    <p class="eyebrow">Let's talk</p>
    <h1>15 minutes. <em>No pitch.</em></h1>
    <p class="lead">Tell us where you are: thinking about selling, sitting on an LOI, or staring at the wire. You'll leave with the questions you should be asking, whether or not we ever work together.</p>
  </div>
</div>
<section style="padding-top:0">
  <div class="wrap" style="max-width:860px">
    <script type="text/javascript" src="https://cdn.oncehub.com/cal/embed.js" async is:inline></script>
    <div data-oh-booking-calendar-id="BKC-X3JXE9RN6W" style="min-width:320px;height:700px;"></div>
  </div>
</section>
</BaseLayout>
