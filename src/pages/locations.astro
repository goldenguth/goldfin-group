---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title={'Locations — Goldfin Group'} description={'Led from Franklin, Tennessee with a client service office in Albuquerque, New Mexico. Serving business owners across the country.'} path={'/locations'}>
<div class="pagehead">
  <div class="wrap">
    <p class="eyebrow">Locations</p>
    <h1>Led from Franklin. <em>Serving owners everywhere.</em></h1>
    <p class="lead">Most of our work happens wherever you are: clients across the country, one deliberately short client list.</p>
  </div>
</div>
<section>
  <div class="wrap">
    <div class="loc-grid">
      <div class="loc">
        <div class="city">Franklin, Tennessee</div>
        <div class="role">Headquarters</div>
        <p>Where Ryan lives, works, and takes the first meeting: downtown Franklin, a 20-minute drive from Nashville.</p>
      </div>
      <div class="loc">
        <div class="city">Albuquerque, New Mexico</div>
        <div class="role">Client Service Office</div>
        <p>Home of our Client Service Director and the operational engine that keeps every plan moving between conversations.</p>
      </div>
    </div>
    <div class="cta-row" style="margin-top:50px">
      <a class="btn btn-gold" href="/book">Book a 15-minute call</a>
      <span class="quiet">No pitch. Just an honest look at where you stand.</span>
    </div>
  </div>
</section>
</BaseLayout>
