---
const { title = "Goldfin Group", description = "Goldfin Group is a wealth management firm headquartered in Franklin, Tennessee, with a client service office in Albuquerque, New Mexico, serving owners of $7 million to $70 million businesses before, during, and after the sale of their companies.", path = "/" } = Astro.props;
const site = "https://goldfin.group";
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "FinancialService",
  "name": "Goldfin Group",
  "description": description,
  "url": site,
  "founder": {
    "@type": "Person",
    "name": "Ryan Guth",
    "jobTitle": "Founder and Chief Strategist, CFP\u00ae",
    "sameAs": [
      "https://www.linkedin.com/in/ryan-guth/"
    ]
  },
  "address": [
    {"@type": "PostalAddress", "addressLocality": "Franklin", "addressRegion": "TN", "addressCountry": "US"},
    {"@type": "PostalAddress", "addressLocality": "Albuquerque", "addressRegion": "NM", "addressCountry": "US"}
  ]
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={site + path} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Sofia+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="/" aria-label="Goldfin Group home"><img class="nav-logo" src="/assets/logo.png" alt="Goldfin Group"></a>
    <button class="nav-toggle" id="navToggle" aria-label="Menu" onclick="toggleNav()"><span></span><span></span><span></span></button>
    <div class="nav-links" id="navLinks">
      <a href="/how-it-works">How it works</a>
      <a href="/services">Services</a>
      <a href="/about">About Ryan</a>
      <a href="/insights">Insights</a>
      <a href="/contact">Contact</a>
      <a class="btn btn-gold" href="/book">Book a 15-minute call</a>
    </div>
   </div>
</nav>
<div class="nav-backdrop" id="navBackdrop"></div>
<main>
  <slot />
</main>
<footer>
  <div class="wrap">
    <img src="/assets/avatar.png" alt="" aria-hidden="true" style="height:44px;width:auto;margin-bottom:24px;opacity:.9">
    <p class="canonical">Goldfin Group is a wealth management firm headquartered in Franklin, Tennessee, with a client service office in Albuquerque, New Mexico, serving owners of $7 million to $70 million businesses before, during, and after the sale of their companies.</p>
    <div class="cols">
      <div><span class="city">Franklin, TN</span><br>Headquarters</div>
      <div><span class="city">Albuquerque, NM</span><br>Client Service</div>
      <div><a class="btn btn-foot" href="/book">Book a 15-minute call</a></div>
    </div>
    <p class="legal">Securities and advisory services offered through LPL Financial, a registered investment advisor. Member FINRA/SIPC. The opinions voiced in this material are for general information only and are not intended to provide specific advice or recommendations for any individual.</p>
  </div>
</footer>

<script is:inline>
function toggleNav(){
  var links = document.getElementById('navLinks');
  var toggle = document.getElementById('navToggle');
  var backdrop = document.getElementById('navBackdrop');
  links.classList.toggle('open');
  toggle.classList.toggle('open');
  backdrop.classList.toggle('open');
}
function closeNav(){
  document.getElementById('navLinks').classList.remove('open');
  document.getElementById('navToggle').classList.remove('open');
  document.getElementById('navBackdrop').classList.remove('open');
}
document.addEventListener('DOMContentLoaded', function(){
  var backdrop = document.getElementById('navBackdrop');
  backdrop.addEventListener('click', closeNav);
  backdrop.addEventListener('touchstart', function(e){ e.preventDefault(); closeNav(); }, {passive:false});
});
</script>
<a 
  href="https://brokercheck.finra.org" 
  target="_blank" 
  rel="noopener noreferrer"
  style="position:fixed;bottom:24px;right:24px;z-index:999;display:flex;align-items:center;gap:8px;background:var(--ink);color:var(--bone);font-family:var(--sans);font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;padding:10px 14px;border-radius:2px;opacity:.75;transition:opacity .2s"
  onmouseover="this.style.opacity='1'"
  onmouseout="this.style.opacity='.75'"
  aria-label="FINRA BrokerCheck — verify our background"
>
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <circle cx="7" cy="7" r="6" stroke="#CB9F5A" stroke-width="1.2"/>
    <path d="M7 4v4M7 9.5v.5" stroke="#CB9F5A" stroke-width="1.2" stroke-linecap="round"/>
  </svg>
  BrokerCheck
</a>

<script is:inline>
if (window.netlifyIdentity) {
  window.netlifyIdentity.on("init", user => {
    if (!user) {
      window.netlifyIdentity.on("login", () => {
        document.location.href = "/admin/";
      });
    }
  });
}
</script>

</body>
</html>
